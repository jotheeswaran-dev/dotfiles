# file location: ${DOTFILES_DIR}/.gitignore

*.zwc*
.*.zwc*
/.ruby-lsp/*

# Session-specific work products (transactional, no long-term value)
/.ai/session-state/

# Claude Code machine-local settings
/.claude/settings.local.json

# tmux plugins are cloned at runtime by tpm — never tracked
files/--HOME--/.config/tmux/plugins/
