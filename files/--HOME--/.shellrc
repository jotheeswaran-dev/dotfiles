  # reinstall_xcode() {
  #   # delete if already present
  #   delete_directory_if_exists '/Applications/Xcode.app'

  #   xcode-select --install
  #   sudo xcodebuild -license accept -quiet || true
  #   success 'Successfully installed xcode'
  # }
