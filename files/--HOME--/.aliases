#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

################################################################################
# This file is sourced at the end of the .zshrc file and loads aliases & functions
#
# file location: ${HOME}/.aliases
# load order: .zshenv [.shellrc], .zshrc [.shellrc, .aliases [.shellrc]], .zlogin
################################################################################

# execute 'DEBUG=true zsh' to debug the load order of the custom zsh configuration files
[[ -n "${DEBUG+1}" ]] && echo "loading ${0}"

# DUPLICATE! Copied over since we get an error if the .shellrc was not loaded
type is_shellrc_sourced &>/dev/null || source "${HOME}/.shellrc"

# ==============================================================================
# GROUP 3: Ongoing Daily-Use Aliases & Functions
# Loaded after .shellrc via .zshrc. These are convenience wrappers, maintenance
# tools, and project-specific helpers used during interactive shell sessions.
# ==============================================================================

# --------------------------------------------------------------------------
# 3a. Shell defaults — extended flags on built-in commands
# --------------------------------------------------------------------------
alias less="${aliases[less]:-less} -RF"
alias cp="${aliases[cp]:-cp} -p"
alias mkdir="${aliases[mkdir]:-mkdir} -p"
alias grep="${aliases[grep]:-grep} -Hn --color=auto --exclude-dir={.zsh_sessions,.IdentityService,.Trash} --exclude={\".*history\",\".zcompdump*\",\"*.zwc*\",\".*.zwc*\"}"
alias fgrep="${aliases[fgrep]:-fgrep} -Hn --color=auto --exclude-dir={.zsh_sessions,.IdentityService,.Trash} --exclude={\".*history\",\".zcompdump*\",\"*.zwc*\",\".*.zwc*\"}"
alias egrep="${aliases[egrep]:-egrep} -Hn --color=auto --exclude-dir={.zsh_sessions,.IdentityService,.Trash} --exclude={\".*history\",\".zcompdump*\",\"*.zwc*\",\".*.zwc*\"}"

# --------------------------------------------------------------------------
# 3b. Tool replacements — enhanced CLI tools
# --------------------------------------------------------------------------
# eza already defines 'll' - so skip if that's present
! command_exists eza && alias ll='ls -la'
command_exists tree && alias tree="${aliases[tree]:-tree} -Ch"
command_exists vim && alias vi='vim'
command_exists prettyping && alias ping='prettyping --nolegend'
command_exists bat && alias cat='bat'
command_exists btop && alias top='btop'
command_exists ncdu && alias du='ncdu --color dark -r -x --exclude .git --exclude .svn --exclude node_modules --exclude .npm --exclude .nuget --exclude Library'

# --------------------------------------------------------------------------
# 3c. Multi-repo git shortcuts (via run-all.sh)
# --------------------------------------------------------------------------
if command_exists 'run-all.sh'; then
  # shortcuts to handle multiple git repos bypassing the omz auto-correct prompt for 'git'
  alias rug='run-all.sh git'
  alias all="FOLDER='${HOME}' MAXDEPTH=6 rug"
  alias home="FOLDER='${HOME}' FILTER='.bin|.dotfiles|zsh|mise' MAXDEPTH=5 rug"
  is_directory "${PERSONAL_PROFILES_DIR}" && alias profiles="FOLDER='${PERSONAL_PROFILES_DIR}' MAXDEPTH=5 rug"
  if is_directory "${PROJECTS_BASE_DIR}"; then
    local -A seen_parent_folders
    local -a parent_folders

    # process substitution keeps 'while' in the current shell (no subshell for the loop body);
    # :h replaces $(dirname ...) with a zsh parameter expansion (no fork per iteration);
    # associative array replaces 'sort -u' piped through an external process
    while IFS= read -r p; do
      local ancestor="${p:h:h}" # parent of .git = repo root; parent of that = first ancestor to check
      while [[ "${ancestor}" != "${PROJECTS_BASE_DIR}" && "${ancestor}" != "/" ]]; do
        if is_zero_string "${seen_parent_folders[$ancestor]}"; then
          seen_parent_folders[$ancestor]=1
          parent_folders+=("${ancestor}")
        fi
        ancestor="${ancestor:h}"
      done
    done < <(find "${PROJECTS_BASE_DIR}" -maxdepth 6 -type d -name '.git')

    if [[ ${#parent_folders[@]} -gt 0 ]]; then
      for folder_path in "${parent_folders[@]}"; do
        local relative_path="${folder_path#${PROJECTS_BASE_DIR}/}"
        local hyphenated_txt="${relative_path//\//-}"
        alias "${hyphenated_txt}"="FOLDER='${folder_path}' MAXDEPTH=4 rug" # alias name is the folder name with the base dir removed and '/' replaced with '-'
      done
      unset folder_path
    fi
  fi
fi

# --------------------------------------------------------------------------
# 3d. Cache & cleanup
# --------------------------------------------------------------------------

delete_caches() {
  # delete the zsh compiled files so that they can be recompiled whenever a new terminal session is next started
  find "${HOME}" "${HOMEBREW_PREFIX}" \( -path '*/.git/*' -o -path '*/node_modules/*' -o -path '*/.mypy_cache/*' -o -path '*/__pycache__/*' \) -prune -o -maxdepth 6 -name '*.zwc*' -type f -print -delete || warn "find command failed in ${HOME} or ${HOMEBREW_PREFIX}"

  # delete the global cache directory
  is_directory "${XDG_CACHE_HOME}" && rm -rfv "${XDG_CACHE_HOME}"
}

# --------------------------------------------------------------------------
# 3e. Repo management & environment setup
# --------------------------------------------------------------------------

resurrect_tracked_repos() {
  if is_non_zero_string "${PERSONAL_CONFIGS_DIR}"; then
    # TODO: Add the github.com host to the known_hosts file so that the script is not blocked for user input
    # ssh-keyscan -H -t ED25519 github.com >> "${SSH_CONFIGS_DIR}/known_hosts"

    # resurrect repositories that are in the repo catalogues
    section_header "$(yellow 'Resurrecting all tracked git repos')"
    # Use zsh glob qualifier (N.) for nullglob and regular files
    for file in "${PERSONAL_CONFIGS_DIR}"/repositories-*.yml(N.); do
      resurrect-repositories.rb -r "${file}"
    done
    unset file
    success 'Successfully resurrected all tracked git repos'
  else
    warn "Skipping resurrecting of repositories since '$(yellow "${PERSONAL_CONFIGS_DIR}")' doesn't exist"
  fi

  # post-clone operations for installing system dependencies
  section_header "$(yellow 'Running post-clone operations')"
  if command_exists all; then
    all restore-mtime -c
    all maintenance register --config-file "${HOME}/.gitconfig-oss.inc"
    all maintenance start
  fi
  allow_all_direnv_configs
  install_mise_versions
}

install_mise_versions() {
  section_header "$(yellow 'Installing mise in all git repos and ancestors')"
  if ! command_exists mise; then
    warn "Couldn't find 'mise' in the PATH; Skipping loading any mise configs"
    return 0
  fi

  local -A seen_dirs
  local -a all_dirs
  local find_maxdepth=6
  [[ -n "${FIRST_INSTALL}" ]] && find_maxdepth=3

  # Find all git repos under HOME, collect them and every ancestor (including HOME itself)
  while IFS= read -r git_dir; do
    local dir="${git_dir:h}"  # strip the trailing /.git to get the repo root
    while [[ "${dir}" != "/" ]]; do
      if is_zero_string "${seen_dirs[$dir]}"; then
        seen_dirs[$dir]=1
        all_dirs+=("${dir}")
      fi
      [[ "${dir}" == "${HOME}" ]] && break  # stop after processing HOME
      dir="${dir:h}"  # walk up one level
    done
  done < <(find "${HOME}" "${DOTFILES_DIR}" "${PROJECTS_BASE_DIR}" -maxdepth ${find_maxdepth} \( -name 'node_modules' -o -name '.cache' -o -name '.oh-my-zsh' -o -name '.Trash' -o -name 'Library' -o -name 'Caches' \) -prune -o -type d -name '.git' -print 2>/dev/null)

  # Sort by depth so parents come before children, then filter to dirs with mise configs
  local mise_configs=('.mise.toml' '.tool-versions' '.ruby-version' '.python-version' '.node-version' '.java-version' '.nvmrc')
  local -a sorted_dirs
  for dir in "${(@on)all_dirs}"; do
    for cfg in "${mise_configs[@]}"; do
      if is_file "${dir}/${cfg}"; then
        sorted_dirs+=("${dir}")
        break
      fi
    done
  done
  unset mise_configs
  local total=${#sorted_dirs}
  local idx=0

  # Fast check — if nothing is missing across all dirs, skip entire processing loop
  local all_installed=true
  for dir in "${sorted_dirs[@]}"; do
    if ! mise install --dry-run-code -C "${dir}" 2>/dev/null; then
      all_installed=false
      break
    fi
  done

  if ${all_installed}; then
    echo "$(green 'All mise tools are already installed')"
    unset sorted_dirs all_dirs seen_dirs
    return
  fi

  for dir in "${sorted_dirs[@]}"; do
    ((idx++))
    echo "$(yellow "[${idx}/${total}] processing '${dir}'")"
    mise -C "${dir}" trust -y -a
    if ! mise install --dry-run-code -C "${dir}" 2>/dev/null; then
      mise -C "${dir}" install
    fi
  done
  unset sorted_dirs
  unset all_dirs
  unset seen_dirs
}

allow_all_direnv_configs() {
  section_header "$(yellow 'Allowing direnv configs in all git repos and ancestors')"
  if ! command_exists direnv; then
    warn "Couldn't find 'direnv' in the PATH; Skipping allowing any direnv configs"
    return 0
  fi

  local -A seen_dirs
  local -a all_dirs
  local find_maxdepth=6
  [[ -n "${FIRST_INSTALL}" ]] && find_maxdepth=3

  # Find all git repos under HOME, collect them and every ancestor (including HOME itself)
  while IFS= read -r git_dir; do
    local dir="${git_dir:h}"  # strip the trailing /.git to get the repo root
    while [[ "${dir}" != "/" ]]; do
      if is_zero_string "${seen_dirs[$dir]}"; then
        seen_dirs[$dir]=1
        all_dirs+=("${dir}")
      fi
      [[ "${dir}" == "${HOME}" ]] && break  # stop after processing HOME
      dir="${dir:h}"  # walk up one level
    done
  done < <(find "${HOME}" "${DOTFILES_DIR}" "${PROJECTS_BASE_DIR}" -maxdepth ${find_maxdepth} \( -name 'node_modules' -o -name '.cache' -o -name '.Trash' -o -name 'Library' -o -name 'Caches' \) -prune -o -type d -name '.git' -print 2>/dev/null)

  # Sort by depth so parents come before children, then filter to dirs with .envrc configs
  local -a sorted_dirs
  for dir in "${(@on)all_dirs}"; do
    if is_file "${dir}/.envrc"; then
      sorted_dirs+=("${dir}")
    fi
  done
  local total=${#sorted_dirs}
  local idx=0

  # Fast check — if nothing is missing across all dirs, skip entire processing loop
  local all_allowed=true
  for dir in "${sorted_dirs[@]}"; do
    pushd "${dir}" &>/dev/null || { all_allowed=false; break }
    if ! direnv status &>/dev/null; then
      all_allowed=false
      popd &>/dev/null || true
      break
    fi
    popd &>/dev/null || true
  done

  if ${all_allowed}; then
    echo "$(green 'All direnv configs are already allowed')"
    unset sorted_dirs all_dirs seen_dirs
    return
  fi

  for dir in "${sorted_dirs[@]}"; do
    ((idx++))
    echo "$(yellow "[${idx}/${total}] allowing direnv for '${dir}'")"
    if direnv allow "${dir}"; then
      success "Successfully allowed direnv for '$(yellow "${dir}")'"
    else
      warn "Failed to allow direnv for '${dir}'"
    fi
  done
  unset sorted_dirs
  unset all_dirs
  unset seen_dirs
}

# --------------------------------------------------------------------------
# 3f. macOS-specific utilities
# --------------------------------------------------------------------------

# generate mac addr to escape some free wifi mac addr restrictions
_free_wifi() {
  local interface="${1}"
  (ifconfig "${interface}" | \grep ether) && \
  (openssl rand -hex 6 | sed 's/\(..\)/\1:/g; s/.$//' | xargs sudo ifconfig "${interface}" ether) && \
  (ifconfig "${interface}" | \grep ether)
}

if is_macos; then
  alias free_wifi='_free_wifi en0'

  alias flush_dns='sudo killall -HUP mDNSResponder;sudo killall mDNSResponderHelper;sudo dscacheutil -flushcache;say MacOS DNS cache has been cleared'

  # MacOS: Remove apps from quarantine
  unquarantine() {
    xattr -rd com.apple.quarantine "${@}"
    open "${@}"
  }

  # MacOS: Clean up LaunchServices to remove duplicates in the "Open With" menu
  alias cleanup_launch_services='/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -kill -r -domain local -domain system -domain user && killall Finder'

  # Show/hide hidden files in Finder
  alias show_hidden_files='defaults write com.apple.finder AppleShowAllFiles -bool true && killall Finder'
  alias hide_hidden_files='defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder'

  # Hide/show all desktop icons (useful when presenting)
  alias hide_desktop='defaults write com.apple.finder CreateDesktop -bool false && killall Finder'
  alias show_desktop='defaults write com.apple.finder CreateDesktop -bool true && killall Finder'

  # Finds and appends the preferences associated with the partial string passed in as an argument.
  # Also, sorts (and removes duplicates) from the config file used to capture preferences
  find_and_append_prefs() {
    local file_name="${DOTFILES_DIR}/scripts/data/capture-prefs-domains.txt"
    defaults find "${1}" | \grep 'keys in domain' | cut -d"'" -f2 >> "${file_name}"
    sort -u -o "${file_name}" "${file_name}"
    unset file_name
  }
elif is_linux; then
  alias free_wifi='_free_wifi eth0'
fi

# --------------------------------------------------------------------------
# 3g. Homebrew utilities
# --------------------------------------------------------------------------

if is_macos && command_exists brew; then
  alias bcg='brew outdated --greedy'
  alias bcug='brew upgrade --greedy'
  alias bupc='brew bundle check || brew bundle --cleanup || true; brew bundle cleanup -f || true; brew cleanup --prune=all || true; brew autoremove || true; brew upgrade || true; post-brew-install.sh || true'

  # brew cask contribution
  check_cask() {
    # shasum -a 256 <fileName>
    # cd $(brew --repository homebrew/cask-versions) &&
    brew audit --online --cask "${1}" && brew style --fix --cask "${1}"
    # cd -
    # brew fetch --cask "${1}"
  }

  # brew contribution
  check_formula() {
    brew install --build-from-source "${1}"
    brew test "${1}"
    brew audit --strict "${1}"
  }
fi

# --------------------------------------------------------------------------
# 3h. Diagnostic & utility functions
# --------------------------------------------------------------------------

# Added to view the shell startup time (modified from https://blog.jonlu.ca/posts/speeding-up-zsh)
time_shell_startup() {
  local shell="${1-${SHELL}}"
  for i in $(seq 1 10); do /usr/bin/time "${shell}" -i -c exit; done
}

if command_exists docker; then
  # docker (TODO: Not sure why this is not done automatically by rancher when it starts up)
  # Note: can't use 'is_file' since testing for sockets is slightly different
  alias start_docker="test -S '${HOME}/.rd/docker.sock' && sudo ln -sf '${HOME}/.rd/docker.sock' /var/run/docker.sock"
  alias stop_docker="test -S /var/run/docker.sock && sudo rm -rf /var/run/docker.sock"
  alias docker_cleanup='docker system prune -a --volumes -f'
  alias docker_list='docker ps -a && docker images'

  show_docker_context_contents() {
    # Based on BMitch's answer from: https://stackoverflow.com/questions/38946683/how-to-test-dockerignore-file
    # Note: this will create and delete temporary file called 'Dockerfile.build-context'
    # Usage:
    # 1. Run this function in the project folder
    # 2. You should see list of files in build context
    # 3. If unwanted files are present, adjust the '.dockerignore' file and go back to step 1

    cat <<EOF > Dockerfile.build-context
  FROM busybox
  COPY . /build-context
  WORKDIR /build-context
  CMD ["find", "."]
EOF

    docker build -f Dockerfile.build-context -t build-context .
    docker run --rm build-context

    rm Dockerfile.build-context
  }
fi

# convert from pdf to png without losing quality
pdf_to_png() {
  if [[ $# -ne 1 ]]; then
    warn "Usage: ${0} <pdf_file>"
    return 1 # Failure, invalid arguments
  fi

  if ! command_exists magick; then
    warn 'Install imagemagick first!'
    return 0 # Success, nothing to do
  fi

  local pdf="${1}"
  local png="${pdf%.*}.png"

  magick -density 800 "${pdf}" -quality 100 "${png}"
}

# Show disk usage of a folder in a colorized format (moved from .shellrc)
folder_size() {
  local folder="${1:-$(pwd)}"
  echo "$(yellow "$(realpath "${folder}")") --> $(cyan "$(/usr/bin/du -sh "${folder}" | cut -f1)")"
}

# --------------------------------------------------------------------------
# 3i. Misc file & path aliases
# --------------------------------------------------------------------------

alias find_broken_links='find . -xtype l -print' # Find links whose targets do not exist
alias clear_logs='rm -rfv */log/*.log'
alias clear_coverage='rm -rfv */coverage */coverage.data'
alias kill_ds='sudo find . -type f -name .DS_Store -print -delete'
alias kill_loc='sudo find . -type f -name .localized -print -delete'

# Remove trailing spaces
remove_trailing_find_cmd="find . -type f \( -name '*.*cs*' -o -name '*.*less' -o -name '*.*js*' -o -name '*.*rb' -o -name '*.*ml' -o -name '*.rake' -o -name '*.java' -o -name '*.ts*' \) -print0"
if is_linux || is_windows; then
  # Linux/WSL/Cygwin sed uses -i without an argument for backup suffix
  alias remove_trailing="${remove_trailing_find_cmd} | xargs -0 sed -i 's/[ ]*$//'"
elif is_macos; then
  # macOS sed requires an argument for -i ('' for no backup)
  alias remove_trailing="${remove_trailing_find_cmd} | xargs -0 sed -i '' 's/[ ]*$//'"
fi
unset remove_trailing_find_cmd

# npm
command_exists npm && alias npm_cleanup='npm cache clear --force'

# tmux
if command_exists tmux; then
  alias tmuxn='tmux new-session -A -s'  # start a new tmux session and name it
  alias tmuxa='tmux attach -t'          # attach to a named tmux session
fi

# Editor aliases
if command_exists "$(extract_first_word "${EDITOR}")"; then
  if is_zsh; then
    # associate file extensions with applications for the 'open' command
    alias -s txt="${EDITOR}"
    alias -s log="${EDITOR}"
  fi

  # add a generic alias for editing files and folders
  alias edit="$(extract_first_word "${EDITOR}")"

  # opens the relevant files and folders (used for laptop provisioning) in a single VSCode session
  alias edit-gist='edit "${DOTFILES_DIR}" "${PERSONAL_BIN_DIR}" "${PERSONAL_CONFIGS_DIR}" "${HOME}"/.gitconfig-* "${HOME}/.gitignore" "${SSH_CONFIGS_DIR}" "${HOME}/.mise.toml" "${PERSONAL_PROFILES_DIR}/.gitignore"'
fi

# --------------------------------------------------------------------------
# 3j. Cron management - dotfiles layer
#
# Contains the higher-level helpers that regenerate crontab from the canonical
# template stored in the dotfiles repo.  These functions reference DOTFILES_DIR,
# HOMEBREW_PREFIX, and PERSONAL_CONFIGS_DIR, so they are only safe to call
# after the dotfiles repo has been cloned and the full shell environment is set
# up (i.e. from within an interactive shell or late in fresh-install-of-osx.sh).
#
# The lower-level primitives (CRON_BACKUP_FILE, restore_cron, suspend_cron,
# resume_cron) live in .shellrc so they are available the moment .shellrc is
# sourced, well before the dotfiles repo exists.  See section 1g in .shellrc.
# --------------------------------------------------------------------------

# internal function - not to be called from outside
_create_crontab() {
  debug 'Creating crontab.txt'
  local file="${1}"

  echo '# Reference: https://crontab.guru/' > "${file}"
  echo >> "${file}"
  echo "# Note: 'chronic' is a utility installed using 'moreutils' from homebrew and is needed so that a successful run of any cron job does not cause a mail to get generated unless in case of error scenarios" >> "${file}"
  echo >> "${file}"
  echo '# Env' >> "${file}"
  echo "SHELL=\"${SHELL}\"" >> "${file}"
  echo "USERNAME=\"${USERNAME}\"" >> "${file}"
  echo "HOME=\"${HOME}\"" >> "${file}"
  echo "PATH=${HOMEBREW_PREFIX}/bin:/usr/bin:/bin  # Needed for chronic to be in the PATH" >> "${file}"
  echo >> "${file}"
  echo "0   */2   *   *   *   chronic zsh -lsc \"${DOTFILES_DIR}/scripts/software-updates-cron.sh | tee -a ${HOME}/software-updates-cron.log\"" >> "${file}"
}

# Regenerates crontab from scratch using the canonical crontab.txt template.
recron() {
  debug 'Setting up crontab'
  local cron_file="${PERSONAL_CONFIGS_DIR}/crontab.txt"
  _create_crontab "${cron_file}"
  restore_cron "${cron_file}"
  success 'Crontab set up successfully'
}

# --------------------------------------------------------------------------
# 3k. Keybase git gc
# --------------------------------------------------------------------------

# runs git gc on the keybase remote repos (not sure if this actually compresses the remote repo or not)
if command_exists keybase; then
  kbgc() {
    if [ $# -ne 1 ]; then
      error "$(red 'Usage:') ${0} $(yellow '<repo name>')\n For eg: '\$KEYBASE_HOME_REPO_NAME' or '\$KEYBASE_PROFILES_REPO_NAME'"
      return
    fi
    keybase git gc --force "${1}"
  }
fi

# --------------------------------------------------------------------------
# 3l. System maintenance
# --------------------------------------------------------------------------

# delete all personal data before re-imaging the laptop
implode() {
  sudo rm -rfv "${HOME}"/.[a-z]*

  local folders=(
    "${DOTFILES_DIR}"
    "${HOME}/personal"
    "${HOMEBREW_BUNDLE_FILE}"
    "${HOMEBREW_PREFIX}"
    "${PROJECTS_BASE_DIR}"
  )
  for f in "${folders[@]}"; do
    sudo rm -rfv "${f}"*
  done
}

# --------------------------------------------------------------------------
# 3m. Project-specific helpers
# --------------------------------------------------------------------------

# common build, debug and launch aliases for any folder - converted to functions for lazy evaluation
# these will use the current folder name to find the shell script to run
launch_me() {
  "${PERSONAL_BIN_DIR}/launch-${PWD##*/}.sh"
}
debug_me() {
  "${PERSONAL_BIN_DIR}/debug-${PWD##*/}.sh"
}
build_me() {
  "${PERSONAL_BIN_DIR}/build-${PWD##*/}.sh"
}

