#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# git command: count

# Source shell helpers if they aren't already loaded
# Re-source guard is inside .shellrc itself — safe to call unconditionally.
source "${HOME}/.shellrc"

# Note: Use a function so that it can accept parameters
count() {
  local folder
  local -a switches
  parse_folder_and_switches "$@"
  section_header2 "$(yellow 'Counting commits') $(purple "${folder}")"
  if ! is_git_repo "${folder}"; then
    warn "Skipping finding count of the repo since '$(yellow "${folder}")' doesn't exist or is not a git repo"
  else
    git -C "${folder}" count "${switches[@]}"
  fi
}

count "$@"
compdef count
