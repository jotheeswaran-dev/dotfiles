# Config generated by Ghostty Config https://ghostty.zerebos.com/

clipboard-trim-trailing-spaces = true
theme = Catppuccin Mocha
confirm-close-surface = false
clipboard-write = allow
confirm-close-surface = false
copy-on-select = true
macos-icon = glass
macos-option-as-alt = true

# ── Font ──────────────────────────────────────────────────────────────────────
# JetBrainsMonoNL Nerd Font Mono Medium 13pt. The "NL" variant has no ligature
# glyphs in the font itself — cleaner than disabling them via font-feature.
# Crisp, conventional glyphs (sane @, $, &, etc.), Medium weight is heavier
# than Regular without going full Bold.
# Renders Powerline arrows + Nerd icons natively (no fallback).
# Switch presets at runtime with the `gfont` zsh alias (meslo|jbm|maple).
font-family = JetBrainsMonoNL Nerd Font Mono
font-size = 13
font-style = Medium
font-style-bold = Bold
